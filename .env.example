# --- Required in production ---
# Bcrypt hash of the admin password. Generate with:
#   node helpers/hash-password.js 'your-password'
ADMIN_PASSWORD_HASH=

# A long random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Optional ---
# Plain password (dev only). Hashed on startup. Ignored if ADMIN_PASSWORD_HASH is set.
# ADMIN_PASSWORD=coffee123

# HTTP port (default 3000)
# PORT=3000

# 'production' enables secure cookies, disables dev warnings.
# NODE_ENV=production

# Behind a reverse proxy? Set to 1 (or the hop count) so Express trusts X-Forwarded-* headers.
# TRUST_PROXY=1

# Display currency + locale (BCP-47). Defaults: USD / en-US.
# CURRENCY=USD
# LOCALE=en-US

# Server timezone. Defaults to the OS default.
# TZ=America/Mexico_City

# Where the SQLite file lives. Default: ./data/tips.db
# DB_PATH=/data/tips.db

# Turn on verbose logging.
# DEBUG=1
