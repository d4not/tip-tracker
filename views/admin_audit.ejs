<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('_head', { pageTitle: t('nav.audit') }) %>
</head>
<body>
  <div class="app" data-page="admin-audit">
    <%- include('_nav') %>
    <main>
      <div class="page-header">
        <h1><%= t('nav.audit') %></h1>
        <div class="subtitle">Recent admin actions and system events.</div>
      </div>

      <% if (!rows || rows.length === 0) { %>
        <div class="empty-state card">
          <span class="emoji">📋</span>
          <p>No audit entries yet.</p>
        </div>
      <% } else { %>
        <div class="table-wrapper sticky-head">
          <table class="audit-table">
            <thead>
              <tr><th>Time</th><th>Actor</th><th>Action</th><th>Target</th><th>Payload</th></tr>
            </thead>
            <tbody>
              <% rows.forEach(function(r) { %>
                <tr>
                  <td><%= r.ts %></td>
                  <td><%= r.actor %></td>
                  <td><code><%= r.action %></code></td>
                  <td><%= r.target || '—' %></td>
                  <td class="payload" title="<%= r.payload || '' %>"><%= r.payload || '—' %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </main>
    <%- include('_footer') %>
  </div>
</body>
</html>
