<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Empleados - Sistema de Propinas</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Arial', sans-serif; background: #f8f9fa; min-height: 100vh; }
        .header {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
            color: white;
            padding: 20px 0;
            text-align: center;
            position: relative;
        }
        .logout-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            padding: 8px 16px;
            background: rgba(255,255,255,0.2);
            color: white;
            text-decoration: none;
            border-radius: 6px;
            font-size: 14px;
        }
        .logout-btn:hover { background: rgba(255,255,255,0.3); }
        .header h1 { font-size: 2rem; margin-bottom: 10px; }
        .container { max-width: 800px; margin: 0 auto; padding: 20px; }
        .nav-buttons { display: flex; gap: 10px; margin-bottom: 30px; flex-wrap: wrap; }
        .nav-btn {
            padding: 10px 20px;
            background: #fff;
            border: 2px solid #667eea;
            color: #667eea;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
        }
        .nav-btn:hover { background: #667eea; color: white; }
        .nav-btn.logout { background: #6c757d; color: white; border-color: #6c757d; }
        .nav-btn.logout:hover { background: #5a6268; }
        .admin-section {
            background: white;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .section-title {
            font-size: 1.5rem;
            color: #333;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #e74c3c;
        }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; color: #555; font-weight: 600; }
        input { width: 100%; padding: 12px; border: 2px solid #ddd; border-radius: 8px; font-size: 16px; }
        input:focus { outline: none; border-color: #e74c3c; }
        .btn {
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
        }
        .btn-primary { background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%); color: white; }
        .btn-primary:hover { box-shadow: 0 5px 15px rgba(231, 76, 60, 0.3); }
        .btn-secondary { background: #6c757d; color: white; }
        .btn-secondary:hover { background: #5a6268; }
        .empleados-list { margin-top: 20px; }
        .empleado-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            margin-bottom: 10px;
        }
        .empleado-info { display: flex; flex-direction: column; }
        .empleado-nombre { font-weight: 600; margin-bottom: 4px; }
        .empleado-actions { display: flex; gap: 8px; }
        .btn-small { padding: 6px 12px; border: none; border-radius: 4px; font-size: 12px; cursor: pointer; }
        .btn-edit { background: #007bff; color: white; }
        .btn-edit:hover { background: #0056b3; }
        .btn-delete { background: #dc3545; color: white; }
        .btn-delete:hover { background: #c82333; }
        .error-message { background: #f8d7da; color: #721c24; padding: 15px; border-radius: 8px; margin-bottom: 20px; }
        @media (max-width: 768px) {
            .container { padding: 10px; }
            .admin-section { padding: 20px; }
            .nav-buttons { flex-direction: column; }
        }
    </style>
</head>
<body>
    <div class="header">
        <a href="/logout" class="logout-btn">🚪 Salir</a>
        <h1>👤 Gestión de Empleados</h1>
        <p>Agregar y editar empleados</p>
    </div>
    <div class="container">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message"><strong>Error:</strong> <%= error %></div>
        <% } %>
        <div class="nav-buttons">
            <a href="/admin" class="nav-btn">← Panel Admin</a>
            <a href="/empleados" class="nav-btn">👥 Vista Empleados</a>
            <a href="/historico" class="nav-btn">📊 Histórico</a>
            <a href="/admin/horario" class="nav-btn">📅 Gestor de la semana</a>
            <a href="/admin/modificacion" class="nav-btn">✏️ Modificar Propinas</a>
            <a href="/logout" class="nav-btn logout">🚪 Cerrar Sesión</a>
        </div>
        <div class="admin-section">
            <h2 class="section-title">Agregar nuevo empleado</h2>
            <div class="form-group">
                <label for="nuevo-empleado">Nombre del empleado:</label>
                <input type="text" id="nuevo-empleado" placeholder="Ej: María González">
            </div>
            <button class="btn btn-secondary" onclick="agregarEmpleado()">Agregar Empleado</button>
        </div>
        <div class="admin-section">
            <h2 class="section-title">Lista de empleados</h2>
            <div class="empleados-list">
                <% const listaEmpleados = typeof empleados !== 'undefined' ? empleados : []; %>
                <% if (listaEmpleados.length === 0) { %>
                    <p style="color: #666; padding: 15px;">No hay empleados. Agrega uno arriba.</p>
                    <button class="btn btn-secondary" onclick="crearEmpleadosPrueba()">Crear empleados de prueba</button>
                <% } else { %>
                    <% listaEmpleados.forEach(empleado => { %>
                        <div class="empleado-item" id="empleado-<%= empleado.id %>">
                            <div class="empleado-info">
                                <span class="empleado-nombre" id="nombre-<%= empleado.id %>"><%= empleado.nombre %></span>
                                <small style="color: #666;">ID: <%= empleado.id %></small>
                            </div>
                            <div class="empleado-actions">
                                <button class="btn-small btn-edit" onclick="editarEmpleado(<%= empleado.id %>, this.getAttribute('data-nombre'))" data-nombre="<%= empleado.nombre %>">✏️ Editar</button>
                                <button class="btn-small btn-delete" onclick="eliminarEmpleado(<%= empleado.id %>, this.getAttribute('data-nombre'))" data-nombre="<%= empleado.nombre %>">🗑️ Eliminar</button>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>
    <script>
        async function agregarEmpleado() {
            const nombre = document.getElementById('nuevo-empleado').value.trim();
            if (!nombre) { alert('Por favor ingresa un nombre'); return; }
            try {
                const response = await fetch('/api/empleados', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre })
                });
                if (response.ok) {
                    alert('Empleado agregado exitosamente');
                    location.reload();
                } else {
                    alert('Error al agregar empleado');
                }
            } catch (error) {
                alert('Error al agregar empleado: ' + error.message);
            }
        }
        async function editarEmpleado(id, nombreActual) {
            const nuevoNombre = prompt('Nuevo nombre:', nombreActual);
            if (!nuevoNombre || nuevoNombre.trim() === '') return;
            try {
                const response = await fetch('/api/empleados/' + id, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre: nuevoNombre.trim() })
                });
                if (response.ok) {
                    document.getElementById('nombre-' + id).textContent = nuevoNombre.trim();
                    alert('Empleado actualizado exitosamente');
                } else {
                    alert('Error al actualizar empleado');
                }
            } catch (error) {
                alert('Error al actualizar empleado: ' + error.message);
            }
        }
        async function eliminarEmpleado(id, nombre) {
            if (!confirm('¿Estás seguro de que quieres eliminar a ' + nombre + '?')) return;
            try {
                const response = await fetch('/api/empleados/' + id, { method: 'DELETE' });
                if (response.ok) {
                    document.getElementById('empleado-' + id).remove();
                    alert('Empleado eliminado exitosamente');
                } else {
                    alert('Error al eliminar empleado');
                }
            } catch (error) {
                alert('Error al eliminar empleado: ' + error.message);
            }
        }
        async function crearEmpleadosPrueba() {
            try {
                const response = await fetch('/create-sample-employees', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                if (response.ok) {
                    const data = await response.json();
                    alert(data.message);
                    location.reload();
                } else {
                    const errorData = await response.json();
                    alert('Error: ' + (errorData.error || 'Error desconocido'));
                }
            } catch (error) {
                alert('Error: ' + error.message);
            }
        }
    </script>
</body>
</html>
