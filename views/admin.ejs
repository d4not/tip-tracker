<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('_head', { pageTitle: t('admin.title') }) %>
  <script src="/js/admin.js" defer></script>
</head>
<body>
  <div class="app" data-page="admin" data-edit-date="<%= editDate || '' %>">
    <%- include('_nav') %>
    <main>
      <div class="page-header">
        <h1><%= t('admin.title') %></h1>
        <div class="subtitle"><%= t('admin.subtitle') %></div>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (setup && (setup.employees === 0 || setup.withSchedule === 0 || setup.tipDays === 0)) { %>
        <section class="onboard" role="region" aria-label="<%= t('admin.onboard.title') %>">
          <div>
            <h3><%= t('admin.onboard.title') %></h3>
            <ul>
              <li class="<%= setup.employees > 0 ? 'done' : '' %>">
                <span class="check"><% if (setup.employees > 0) { %><svg class="icon" aria-hidden="true"><use href="/icons.svg#i-check"/></svg><% } %></span>
                <a href="/admin/employees"><%= t('admin.onboard.step1') %></a>
              </li>
              <li class="<%= setup.withSchedule > 0 ? 'done' : '' %>">
                <span class="check"><% if (setup.withSchedule > 0) { %><svg class="icon" aria-hidden="true"><use href="/icons.svg#i-check"/></svg><% } %></span>
                <a href="/admin/schedule"><%= t('admin.onboard.step2') %></a>
              </li>
              <li class="<%= setup.tipDays > 0 ? 'done' : '' %>">
                <span class="check"><% if (setup.tipDays > 0) { %><svg class="icon" aria-hidden="true"><use href="/icons.svg#i-check"/></svg><% } %></span>
                <span><%= t('admin.onboard.step3') %></span>
              </li>
            </ul>
          </div>
        </section>
      <% } %>

      <div class="card">
        <h2 class="card-title"><%= t('admin.subtitle') %></h2>

        <div class="form-group">
          <label for="tip-date"><%= t('admin.date') %></label>
          <div class="row">
            <input type="date" id="tip-date" class="grow" value="<%= todayStr %>" max="<%= todayStr %>">
            <button type="button" class="btn btn-secondary" id="btn-load" data-action="load-date">
              <svg class="icon" aria-hidden="true"><use href="/icons.svg#i-search"/></svg>
              <%= t('admin.load') %>
            </button>
            <button type="button" class="btn btn-secondary" id="btn-schedule" data-action="apply-schedule">
              <svg class="icon" aria-hidden="true"><use href="/icons.svg#i-calendar"/></svg>
              <%= t('admin.applySchedule') %>
            </button>
          </div>
          <small id="status-msg" class="hint" style="display:block; margin-top:8px;"></small>
        </div>

        <div class="form-group">
          <label for="total-amount"><%= t('admin.amount') %></label>
          <input type="number" id="total-amount" step="0.01" min="0" placeholder="0.00" inputmode="decimal">
          <small id="per-person-preview" class="hint" style="display:block; margin-top:6px;"></small>
        </div>

        <div class="form-group">
          <label><%= t('admin.whoWorked') %></label>
          <div class="row" style="margin-bottom:8px;">
            <button type="button" class="btn btn-sm btn-secondary" data-action="select-all"><%= t('admin.selectAll') %></button>
            <button type="button" class="btn btn-sm btn-secondary" data-action="clear-selection"><%= t('admin.clear') %></button>
          </div>
          <div class="checkbox-grid" id="employees-grid">
            <% if (employees && employees.length > 0) { %>
              <% employees.forEach(function(emp) { %>
                <label class="checkbox-card" data-id="<%= emp.id %>" data-name="<%= emp.name %>">
                  <input type="checkbox" value="<%= emp.id %>">
                  <span class="checkbox-card-name"><%= emp.name %></span>
                  <span class="chip override-chip" hidden></span>
                  <button type="button" class="chip-btn" data-action="override" title="<%= t('admin.overrideTooltip') %>" aria-label="<%= t('admin.override') %>">⚙</button>
                </label>
              <% }); %>
            <% } else { %>
              <div class="empty-state" style="grid-column: 1/-1;">
                <span class="emoji">👤</span>
                <p><%= t('employeesMgmt.empty') %></p>
                <button type="button" class="btn btn-secondary" data-action="create-samples">
                  <svg class="icon" aria-hidden="true"><use href="/icons.svg#i-plus"/></svg>
                  <%= t('employeesMgmt.createSamples') %>
                </button>
              </div>
            <% } %>
          </div>
          <div style="margin-top:8px; font-weight:600; color: var(--primary);">
            <%= t('admin.selected', { n: '' }) %><span id="selected-count">0</span>
          </div>
        </div>

        <div class="form-group">
          <label for="day-notes"><%= t('admin.notes') %></label>
          <textarea id="day-notes" maxlength="500" placeholder="..."></textarea>
        </div>

        <button class="btn btn-primary" id="btn-save" data-action="save-tips">
          <svg class="icon" aria-hidden="true"><use href="/icons.svg#i-check"/></svg>
          <%= t('admin.save') %>
        </button>
      </div>
    </main>
    <%- include('_footer') %>
  </div>
</body>
</html>
